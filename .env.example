# ---- LLM provider -------------------------------------------------------
# Choose one: anthropic | openai | ollama
LLM_PROVIDER=ollama
LLM_MODEL=gpt-oss

# Provider-specific keys (fill in the one matching LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Ollama (local) — base URL only, no key needed
OLLAMA_BASE_URL=http://localhost:11434
# Keep the model resident between requests. "-1" = forever, or a duration like
# "30m". Reduces cold-load latency between calls.
OLLAMA_KEEP_ALIVE=-1
# Structured-output method for Ollama. The strict "json_schema" grammar fails on
# this Ollama build ("failed to load model vocabulary required for format"), so
# use "function_calling" (default) or "json_mode". Needs a tool-calling-capable
# model (e.g. qwen3.5) for good results; gpt-oss:20b often mis-shapes the schema.
OLLAMA_STRUCTURED_OUTPUT_METHOD=function_calling

# ---- Web search ---------------------------------------------------------
# Comma-separated, in priority order. Tavily requires TAVILY_API_KEY.
SEARCH_PROVIDERS=ddg,tavily
TAVILY_API_KEY=

# ---- Target platforms ---------------------------------------------------
# Preliminary search uses PRIMARY (top-3). Expansion adds SECONDARY.
PLATFORMS_PRIMARY=linkedin,github,twitter
PLATFORMS_SECONDARY=facebook,instagram,vk

# ---- Graph behavior -----------------------------------------------------
MAX_ITERATIONS=7

# ---- Scraping -----------------------------------------------------------
PER_HOST_RPS=1.0
USER_AGENT=search4people/0.1 (+https://github.com/kryadov/search4people_v2)
JS_HEAVY_DOMAINS=linkedin.com,instagram.com,facebook.com

# ---- Storage ------------------------------------------------------------
DB_PATH=data/app.db
# Persistent chat history (Chainlit data layer). Separate file from DB_PATH.
CHAT_HISTORY_DB_PATH=data/chat_history.db

# ---- Chainlit -----------------------------------------------------------
# Required by Chainlit's password auth; generate with: openssl rand -hex 32
CHAINLIT_AUTH_SECRET=replace-me-with-a-long-random-secret

# ---- Observability (optional) -------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=search4people

# --- A2A server (uv run s4p-a2a) ---
A2A_HOST=0.0.0.0
A2A_PORT=8001
# Public base URL advertised in the Agent Card (optional; defaults to host:port).
# A2A_PUBLIC_URL=https://your-host.example/
# For the demo client (examples/a2a_demo.py) — mint with: uv run s4p-create-token <user>
# A2A_DEMO_TOKEN=

# ---- Guardrails (GLiNER2 + gliner-guard-omni) ---------------------------
# Master switch. When enabled, the local backend loads two GLiNER2 models from
# HuggingFace on first use (~400MB) and runs them in-process.
GUARDRAILS_ENABLED=true
# local = in-process gliner2 | http = remote sidecar | noop = disabled
GUARDRAILS_BACKEND=local
# Safety/abuse classifier and PII NER models (HuggingFace ids).
GUARDRAILS_SAFETY_MODEL=hivetrace/gliner-guard-omni
GUARDRAILS_PII_MODEL=fastino/gliner2-base-v1
# auto | cpu | cuda
GUARDRAILS_DEVICE=auto
# open = keep searching if the guard model errors; closed = block on error.
GUARDRAILS_FAIL_MODE=open
# Required only when GUARDRAILS_BACKEND=http.
# GUARDRAILS_HTTP_URL=http://localhost:8002
